generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Score {
  id         Int      @id @default(autoincrement())
  playerName String
  score      Int
  total      Int
  percent    Int
  topic      String
  createdAt  DateTime @default(now())
}
